# =============================================================================
# apps/mobile — Expo / Metro
# =============================================================================
# Copy to apps/mobile/.env and fill in real values:
#   cp apps/mobile/.env.example apps/mobile/.env
#
# Expo loads `.env` from this app directory and only embeds EXPO_PUBLIC_* into the
# JS bundle. Do not put NEXT_PUBLIC_* here — Expo ignores those names for bundling
# and they only add noisy `env: export ...` logs.
# Shared setup notes: repo-root `.env.example` and docs/DEV_SETUP.md.
#
# Supabase keys: Dashboard → Settings → API Keys → publishable (`sb_publishable_…`).
#   Use the same project URL and publishable key as the Next apps; different prefix only.
#   https://supabase.com/docs/guides/api/api-keys
# This repo does not use legacy JWT anon env vars or SUPABASE_SERVICE_ROLE_KEY.
# -----------------------------------------------------------------------------

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Same origin as NEXT_PUBLIC_USER_WEB_ORIGIN on user web (caretaker invite / App Links).
EXPO_PUBLIC_USER_WEB_ORIGIN=http://localhost:3000

# PowerSync Service HTTP/WebSocket endpoint for offline replication
# (configure instance + upload packages/powersync/sync-rules.yaml).
# Copy the current instance URL from the PowerSync Dashboard — it may change if the
# Cloud project was disabled and re-enabled (see docs/SUPABASE_CLOUD_DEVELOPER.md).
EXPO_PUBLIC_POWERSYNC_URL=https://YOUR_POWERSYNC_INSTANCE.example.com
