# =============================================================================
# apps/web — user web (Next.js)
# =============================================================================
# Copy to apps/web/.env.local and fill in real values:
#   cp apps/web/.env.example apps/web/.env.local
#
# Next.js reads `.env.local` from this app directory (not the repo root).
# Shared setup notes: repo-root `.env.example` and docs/DEV_SETUP.md.
#
# Supabase keys: Dashboard → Settings → API Keys
#   publishable (`sb_publishable_…`) for clients; secret (`sb_secret_…`) server-only.
#   https://supabase.com/docs/guides/api/api-keys
# This repo does not use legacy JWT anon env vars or SUPABASE_SERVICE_ROLE_KEY.
# -----------------------------------------------------------------------------

# Safe to expose in the browser bundle
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Canonical site URL for SEO (metadataBase, sitemap, Open Graph).
# Production: https://abstrack.org
# Mobile uses EXPO_PUBLIC_USER_WEB_ORIGIN with the same origin (Universal Links / App Links).
NEXT_PUBLIC_USER_WEB_ORIGIN=http://localhost:3000

# Optional: TOTP issuer name in authenticator apps (falls back to "ABStrack").
# NEXT_PUBLIC_APP_NAME=ABStrack

# MFA device trust (localStorage session bundle).
# Omit or leave empty for default (enabled). Use true or 1 to enable; false or 0 to disable.
# Any other non-empty value is treated as disabled (fail-closed).
# NEXT_PUBLIC_USER_MFA_DEVICE_TRUST=false

# Client-visible CSP Phase B flag (paired with USER_WEB_CSP_ENFORCE below).
# NEXT_PUBLIC_USER_WEB_CSP_ENFORCE=true

# CSP — read at Next config load / build (not exposed to the browser).
# Default: Content-Security-Policy-Report-Only. Set to true to enforce (Phase B).
# USER_WEB_CSP_ENFORCE=true

# Server-only (optional; uncomment when a server route or script imports @abstrack/supabase/admin).
# Never NEXT_PUBLIC_* or client bundles.
# SUPABASE_SECRET_KEY=sb_secret_your_key
