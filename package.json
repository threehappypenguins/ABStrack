{
  "name": "@abstrack/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "web": "nx dev web",
    "web:lint": "nx lint web",
    "web:test": "nx test web",
    "web:build": "nx build web",
    "web:validate": "nx run-many -t lint test -p web",
    "web:e2e": "nx e2e @abstrack/web-e2e",
    "practitioner": "nx dev practitioner",
    "practitioner:lint": "nx lint practitioner",
    "practitioner:test": "nx test practitioner",
    "practitioner:build": "nx build practitioner",
    "practitioner:validate": "nx run-many -t lint test -p practitioner",
    "practitioner:e2e": "nx e2e @abstrack/practitioner-e2e",
    "a11y:e2e": "nx run-many -t e2e -p @abstrack/web-e2e,@abstrack/practitioner-e2e --parallel=1 -- --grep @a11y --project=chromium --workers=1",
    "a11y:lint": "nx run-many -t lint -p web,practitioner,mobile,ui",
    "a11y": "pnpm a11y:lint && pnpm a11y:e2e",
    "mobile": "cd apps/mobile && pnpm expo start",
    "mobile:lint": "nx lint mobile",
    "mobile:test": "nx test mobile",
    "mobile:typecheck": "nx typecheck mobile",
    "mobile:validate": "pnpm mobile:lint && pnpm mobile:test",
    "supabase:lint": "nx lint @abstrack/supabase",
    "supabase:test": "nx test @abstrack/supabase",
    "supabase:typecheck": "nx run @abstrack/supabase:typecheck",
    "supabase:validate": "nx run-many -t lint test typecheck -p @abstrack/supabase",
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test",
    "build": "nx run-many -t build -p web,practitioner && pnpm mobile:typecheck && pnpm supabase:typecheck",
    "typecheck": "nx typecheck mobile",
    "validate": "nx run-many -t lint test",
    "android": "cd apps/mobile && pnpm expo run:android",
    "ios": "cd apps/mobile && pnpm expo run:ios"
  },
  "private": true,
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@babel/runtime": "~7.27.6",
    "@eslint/js": "^9.8.0",
    "@expo/cli": "~54.0.16",
    "@next/eslint-plugin-next": "^16.0.1",
    "@nx/devkit": "22.5.4",
    "@nx/eslint": "^22.5.4",
    "@nx/eslint-plugin": "22.5.4",
    "@nx/expo": "^22.5.4",
    "@nx/jest": "22.5.4",
    "@nx/js": "22.5.4",
    "@nx/next": "^22.5.4",
    "@nx/playwright": "22.5.4",
    "@nx/react-native": "^22.5.4",
    "@nx/vite": "^22.5.4",
    "@nx/vitest": "22.5.4",
    "@playwright/test": "^1.36.0",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@testing-library/dom": "10.4.0",
    "@testing-library/react": "16.3.0",
    "@testing-library/react-native": "~13.2.0",
    "@types/jest": "^30.0.0",
    "@types/node": "20.19.9",
    "@types/react": "~19.1.0",
    "@types/react-dom": "~19.1.0",
    "@vitest/coverage-v8": "^4.0.0",
    "autoprefixer": "10.4.13",
    "babel-jest": "^30.0.2",
    "babel-preset-expo": "~54.0.7",
    "baseline-browser-mapping": "^2.10.10",
    "eslint": "^9.8.0",
    "eslint-config-next": "^16.0.1",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-playwright": "^1.6.2",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "eslint-plugin-react-native-a11y": "^3.5.1",
    "jest": "^30.0.2",
    "jest-environment-jsdom": "^30.0.2",
    "jest-expo": "~54.0.13",
    "jest-util": "^30.0.2",
    "jsonc-eslint-parser": "^2.1.0",
    "metro-config": "~0.83.0",
    "metro-resolver": "~0.83.0",
    "nx": "22.5.4",
    "postcss": "8.4.38",
    "prettier": "~3.6.2",
    "react-test-renderer": "19.1.0",
    "tailwindcss": "3.4.3",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^7.0.0",
    "vitest": "^4.0.8"
  },
  "dependencies": {
    "@expo/metro-config": "~54.0.9",
    "@expo/metro-runtime": "~6.1.2",
    "expo": "~54.0.0",
    "expo-splash-screen": "~31.0.11",
    "expo-status-bar": "~3.0.8",
    "expo-system-ui": "~6.0.8",
    "next": "~16.0.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-svg": "15.12.1",
    "react-native-svg-transformer": "~1.5.1",
    "react-native-web": "~0.21.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "~19.1.0",
      "@types/react-dom": "~19.1.0"
    }
  }
}
